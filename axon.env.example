# AXON Environment Config
# Copy this file to axon.env and fill in your keys.
# axon.env is gitignored — your keys stay private.

# Serper.dev — free Google Search API (2,500 queries/month, no credit card)
# Sign up at: https://serper.dev/signup
SERPER_API_KEY=your_key_here

# Anthropic Claude fallback (optional — only if not using LM Studio)
# ANTHROPIC_API_KEY=your_key_here
